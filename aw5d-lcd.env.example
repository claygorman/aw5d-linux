# aw5d-lcd configuration.
# Copy to ~/.config/aw5d-lcd.env, edit, then:  systemctl --user restart aw5d-lcd
# (install.sh drops a copy here for you on first install.)

# How often to push CPU stats to the LCD, in seconds.
# The cooler's firmware refreshes the gauge at ~1 Hz, so:
#   1      = ideal (default)
#   2 - 5  = fine, and a touch lighter on CPU/USB
#   < 0.5  = NOT recommended — extra USB/CPU traffic with no visible benefit
#   0      = would busy-loop; the driver clamps to 0.05s and warns
AW5D_INTERVAL=1
